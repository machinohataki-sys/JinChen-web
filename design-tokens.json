{
  "colors": {
    "bg-primary": "#0f0a0a",
    "bg-secondary": "#170f10",
    "bg-tertiary": "#261a1c",
    "bg-card": "#1c1315",
    "text-primary": "#ffffff",
    "text-secondary": "rgba(255, 255, 255, 0.6)",
    "text-muted": "rgba(255, 255, 255, 0.35)",
    "accent-gold": "#c9a96e",
    "accent-gold-light": "#e0c992",
    "accent-gold-dim": "rgba(201, 169, 110, 0.4)",
    "accent-crystal": "#a8d8ea",
    "accent-teal": "rgba(78, 205, 196, 0.8)",
    "accent-teal-dim": "rgba(78, 205, 196, 0.6)",
    "highlight": "#ffffff",
    "error": "#e05555",
    "success": "#55b87a",
    "border-subtle": "rgba(255, 255, 255, 0.06)",
    "border-hover": "rgba(255, 255, 255, 0.15)",
    "glass-bg": "rgba(255, 255, 255, 0.03)",
    "glass-border": "rgba(255, 255, 255, 0.06)",
    "overlay-dark": "rgba(10, 10, 15, 0.85)",
    "prismatic": {
      "red": "#ff6b6b",
      "teal": "#4ecdc4",
      "blue": "#45b7d1",
      "yellow": "#f9ca24",
      "purple": "#a29bfe"
    }
  },
  "typography": {
    "font-display": "'Playfair Display', Georgia, 'Times New Roman', serif",
    "font-body": "system-ui, -apple-system, 'Segoe UI', sans-serif",
    "font-mono": "'SF Mono', ui-monospace, monospace",
    "scale": {
      "hero-title": "clamp(3rem, 8vw, 7rem)",
      "section-title": "clamp(2rem, 4vw, 3.5rem)",
      "subtitle": "clamp(1.1rem, 2vw, 1.4rem)",
      "body": "1rem",
      "body-small": "0.9rem",
      "caption": "0.8rem",
      "label": "0.75rem"
    },
    "line-height": {
      "heading": 1.1,
      "subtitle": 1.4,
      "body": 1.7
    },
    "letter-spacing": {
      "heading": "-0.02em",
      "label": "0.08em",
      "body": "0"
    },
    "font-weight": {
      "regular": 400,
      "bold": 700
    }
  },
  "layout": {
    "max-width": "1200px",
    "section-padding": "120px",
    "grid-gap": "clamp(20px, 3vw, 48px)",
    "border-radius": {
      "card": "16px",
      "button": "8px",
      "input": "8px",
      "pill": "80px",
      "glass": "20px"
    }
  },
  "transitions": {
    "fast": "0.15s ease",
    "default": "0.3s cubic-bezier(0.4, 0, 0.2, 1)",
    "slow": "0.6s cubic-bezier(0.16, 1, 0.3, 1)",
    "spring": "0.5s cubic-bezier(0.34, 1.56, 0.64, 1)",
    "ease-out-expo": "cubic-bezier(0.16, 1, 0.3, 1)"
  },
  "shadows": {
    "card": "0 4px 24px rgba(0, 0, 0, 0.3)",
    "card-hover": "0 8px 40px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(255, 255, 255, 0.1)",
    "glow-gold": "0 0 20px rgba(201, 169, 110, 0.15)",
    "glow-teal": "0 0 30px rgba(78, 205, 196, 0.08)",
    "glow-crystal": "0 0 30px rgba(168, 216, 234, 0.1)"
  },
  "z-index": {
    "base": 1,
    "card": 10,
    "nav": 100,
    "overlay": 200,
    "modal": 300,
    "preloader": 9999
  }
}
